PORT=5000
MONGODB_URI=mongodb://localhost:27017/file-manager
# External filesystem root for file and folder storage (metadata stays in MongoDB).
STORAGE_ROOT=C:\Uploads
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
# Comma-separated browser origins allowed to call the API with cookies.
# Production example (required for https://db.example.com -> https://api.example.com):
# FRONTEND_URL=https://db.example.com
# With COOKIE_CROSS_ORIGIN=true, sibling subdomains on the same domain are also allowed.
FRONTEND_URL=http://localhost:5173,http://192.168.107.48:5173
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-password
NODE_ENV=development
# Trust one reverse-proxy hop (Vite dev proxy or nginx). Required for express-rate-limit with X-Forwarded-For.
TRUST_PROXY=1
# Set to true only for direct cross-origin HTTPS API calls (not needed with Vite proxy).
# COOKIE_CROSS_ORIGIN=false
# Optional total storage display limit for dashboard (bytes). Default: 55GB.
# USER_STORAGE_LIMIT=59055800320
# Reverse proxy: default nginx client_max_body_size is 1m. Uploads over ~1 MB fail
# unless raised to match the app limit. See deploy/nginx-api.conf.example.
# Registration is restricted to authorized roles. Super Admin is always allowed.
# Set to false to forbid Admins from registering new accounts (Super Admin only).
# ALLOW_ADMIN_REGISTER=true