# API server address for the Vite dev proxy (use when client and server run on different machines).
# The browser should call /api on this app; Vite forwards those requests here.
VITE_API_TARGET=http://192.168.107.48:5001

# Optional: call the API directly instead of the proxy (requires HTTPS + COOKIE_CROSS_ORIGIN=true on server).
# VITE_API_URL=http://192.168.107.48:5001/api
